---
interface Paso {
  numero: number;
  titulo: string;
  descripcion: string;
  tiempo: string;
}

const PASOS: Paso[] = [
  {
    numero: 1,
    titulo: "Contacto y análisis",
    descripcion: "Hablamos sobre tu idea, objetivos y necesidades para definir el alcance del proyecto.",
    tiempo: "1 día"
  },
  {
    numero: 2,
    titulo: "Cotización y propuesta",
    descripcion: "Recibes una propuesta clara con estructura del proyecto, tiempos y costos.",
    tiempo: "2 días"
  },
  {
    numero: 3,
    titulo: "Desarrollo del proyecto",
    descripcion: "Desarrollo del sitio web con revisiones constantes para asegurar calidad y funcionalidad.",
    tiempo: "5 días"
  },
  {
    numero: 4,
    titulo: "Entrega y lanzamiento",
    descripcion: "Publicación del sitio y configuración final para que tu proyecto esté en línea.",
    tiempo: "1 día"
  }
];
---

<!-- ======================= SECCIÓN DE PROCESO =========================== -->
<section id="process" class="py-24 px-6">

  <!-- Header -->
  <div class="max-w-2xl mx-auto text-center mb-16">
    <h2 class="text-3xl font-semibold mb-4">
      Proceso simple <span class="text-blue-400">en 4 pasos</span>
    </h2>

    <p class="text-gray-400">
      Transformamos tu concepto digital en un producto funcional y optimizado
      siguiendo un proceso claro y estructurado.
    </p>
  </div>

  <!-- Timeline -->
  <div class="relative">
    
    <!-- Línea principal -->
    <div class="absolute top-8 left-0 right-0 h-0.5 bg-blue-400/30"></div>
    
    <!-- Pasos en una sola línea -->
    <div class="relative flex justify-between items-start px-8">
      {PASOS.map((paso, index) => (
        <div class="relative flex flex-col items-center text-center mx-4 flex-1">
          
          <!-- Punto de posición -->
          <div class="relative z-10 mb-4">
            <div class="w-8 h-8 bg-blue-400 rounded-full flex items-center justify-center text-white text-sm font-semibold">
              {paso.numero}
            </div>
          </div>
          
          <!-- Contenido -->
          <div class="glass-container px-4 py-8 flex-1 flex flex-col justify-between min-h-[210px]">
            <div class="flex-1 flex flex-col justify-between space-y-2">
              <h3 class="text-lg font-semibold">
                {paso.titulo}
              </h3>
              
              <p class="text-sm text-gray-400">
                {paso.descripcion}
              </p>
              
              <span class="text-xs text-gray-500">
                {paso.tiempo}
              </span>
            </div>
          </div>
          
        </div>
      ))}
    </div>
    
  </div>

</section>
