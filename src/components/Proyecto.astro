---
import { getCollection } from "astro:content";
import ExperienciaIcon from './icons/experiencia-icon.astro';

const proyectos = await getCollection("proyectos");

proyectos.sort((a, b) => b.data.date - a.data.date);

const proyectosLimitados = proyectos.slice(0, 3);
---

<section class="">
  <div class="flex items-center gap-2 mb-8 -ml-2">
        <ExperienciaIcon class="w-6 h-6 fill-white" />
        <h2 class="text-3xl font-bold ">Proyectos destacados</h2>
    </div>

  <div class="space-y-20 max-w-6xl mx-auto">
    
    {proyectosLimitados.map((proyecto) => (
      <article class="flex flex-col md:flex-row gap-8 items-start">
        <a href={proyecto.data.link} target="_blank" class="w-full md:w-1/2 rounded-xl overflow-hidden shadow-2xl flex items-center justify-center group hover:scale-105 transition-transform">
          <img src={proyecto.data.image} alt={proyecto.data.title} class="w-full h-auto object-cover">
        </a>
        
        <div class="w-full md:w-1/2 space-y-4">
          <h3 class="text-2xl font-bold leading-tight">{proyecto.data.title}</h3>
          
          <div class="flex gap-2">
            <span class="flex items-center gap-1 bg-black border border-white/20 px-3 py-1 rounded-full text-xs font-medium text-gray-300">
              <span class="w-2 h-2 bg-white rounded-full"></span> Web Development
            </span>
            {proyecto.data.tags.slice(0, 2).map((tag) => (
              <span class="flex items-center gap-1 bg-[#003159] border border-[#00d8ff]/30 px-3 py-1 rounded-full text-xs font-medium text-[#00d8ff]">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12.001 4.8c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624C13.666 10.618 15.027 12 18.201 12c3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C16.537 6.182 15.176 4.8 12.001 4.8z"/></svg>
                {tag}
              </span>
            ))}
          </div>

          <p class="leading-relaxed">
            {proyecto.data.description}
          </p>
        </div>
      </article>
    ))}

  </div>

  <!-- Botón para ver todos los proyectos -->
  <div class="text-center mt-12">
    <a href="/proyectos" class="inline-flex items-center gap-2 px-6 py-3 glass-boton font-semibold rounded-full hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-cyan-500/25">
      Ver todos los proyectos
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>
  </div>
</section>