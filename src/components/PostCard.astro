---
const { title, description, image, url, date } = Astro.props;
---

<a href={url} class="block glass-container rounded-xl overflow-hidden hover:scale-[1.02] transition-all duration-300 hover:shadow-xl">

  <div class="relative overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-48 object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
  </div>

  <div class="p-6">

    <p class="text-sm opacity-70">
      {date.toLocaleDateString()} 
    </p>

    <h3 class="text-xl font-bold mt-3 hover:text-cyan-400 transition-colors">
      {title}
    </h3>

    <p class="mt-3  line-clamp-3">
      {description}
    </p>

    
  </div>

</a>