---
---

<!-- ======================= SECCIÓN CONTACTO =========================== -->
<section id="contact" class="py-24 px-6">

  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <h2 class="text-3xl font-semibold mb-3">
        No dudes en <span class="text-blue-400">contactarme</span>
      </h2>
      <p class="text-gray-400">
        Hablemos de tu proyecto o cualquier idea que quieras desarrollar.
      </p>
    </div>

    <!-- Contenedor -->
    <div class="grid md:grid-cols-2 gap-10">

      <!-- Formulario -->
      <div class="border rounded-xl p-8 glass-container">

        <h3 class="text-xl font-medium mb-6 text-center">
          Envíame un mensaje
        </h3>

        <form
          action="https://formsubmit.co/luisgerdx521@gmail.com"
          method="POST"
          class="space-y-4"
        >

          <input
            type="text"
            name="name"
            placeholder="Nombre"
            required
            class="w-full px-5 py-[15px] border border-blue-400/40 text-gray-300 rounded-lg text-base outline-none transition-all duration-300 focus:border-blue-400 focus:shadow-lg"
          />

          <input
            type="tel"
            name="phone"
            placeholder="Número de teléfono"
            class="w-full px-5 py-[15px] border border-blue-400/40 text-gray-300 rounded-lg text-base outline-none transition-all duration-300 focus:border-blue-400 focus:shadow-lg"
          />

          <input
            type="email"
            name="email"
            placeholder="Correo electrónico"
            required
            class="w-full px-5 py-[15px] border border-blue-400/40 text-gray-300 rounded-lg text-base outline-none transition-all duration-300 focus:border-blue-400 focus:shadow-lg"
          />

          <textarea
            name="message"
            placeholder="Tu mensaje"
            rows="5"
            required
            class="w-full px-5 py-[15px] border border-blue-400/40 text-gray-300 rounded-lg text-base outline-none transition-all duration-300 focus:border-blue-400 focus:shadow-lg"
          ></textarea>

          <button
            type="submit"
            class="w-full border rounded-full py-3 font-medium glass-style hover:bg-gray-100 transition"
          >
            Enviar mensaje
          </button>

        </form>

      </div>

      <!-- Redes -->
      <div class="border rounded-xl p-8 text-center flex flex-col justify-center glass-container">

        <h3 class="text-xl font-medium mb-3">
          Conéctate conmigo
        </h3>

        <p class="text-gray-400 mb-8">
          También puedes encontrarme aquí
        </p>

        <div class="flex justify-center gap-6 text-xl">

          <a href="tel:+522288535112" class="hover:scale-110 transition">
            <i class="fa-solid fa-phone"></i>
          </a>

          <a href="mailto:luisgerdx521@gmail.com" class="hover:scale-110 transition">
            <i class="fa-solid fa-envelope"></i>
          </a>

          <a href="https://wa.me/522288535112" class="hover:scale-110 transition">
            <i class="fa-brands fa-whatsapp"></i>
          </a>

        </div>

      </div>

    </div>

  </div>

</section>
