---
interface Card {
  icon: string;
  title: string;
  description: string;
}

const CARDS: Card[] = [
  {
    icon: "fa-rocket",
    title: "Rápido y Eficiente",
    description: "Desarrollo ágil con entrega en tiempos récord sin comprometer la calidad."
  },
  {
    icon: "fa-mobile-alt",
    title: "100% Responsivo",
    description: "Diseño adaptado para todos los dispositivos y tamaños de pantalla."
  },
  {
    icon: "fa-search",
    title: "SEO Optimizado",
    description: "Código limpio y estructurado para mejor posicionamiento en buscadores."
  },
  {
    icon: "fa-shield-alt",
    title: "Seguro y Confiable",
    description: "Prácticas de seguridad modernas para proteger tu sitio y usuarios."
  }
];
---

<!-- ======================= SECCIÓN CARDS =========================== -->
<section id="cards" class="py-24 px-6">

  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl font-semibold mb-4">
        Por qué <span class="text-blue-400">elegirme</span>
      </h2>
      <p class="text-gray-400">
        Características que hacen la diferencia en cada proyecto
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {CARDS.map((card) => (
        <div class="glass-container p-8 text-center">
          
          <!-- Icono -->
          <div class="w-16 h-16 bg-blue-400/20 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class={`fas ${card.icon} text-blue-400 text-2xl`}></i>
          </div>
          
          <!-- Contenido -->
          <h3 class="text-xl font-semibold mb-3">
            {card.title}
          </h3>
          
          <p class="text-gray-400">
            {card.description}
          </p>
          
        </div>
      ))}
    </div>

  </div>

</section>
